# --- Supabase (data plane: libraries, library_tags, fn_* function tables) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# --- Redis Stack (W-TinyLFU semantic cache — separate from data plane) ---
# Must point at a Redis Stack instance (RediSearch + RedisBloom).
REDIS_URL=redis://[username]:[password]@[host]:[port]
# Individual Redis connection variables (used by config.py)
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=

# --- Anthropic (recommend_library rerank/synthesis) ---
ANTHROPIC_API_KEY=
RERANK_MODEL=claude-sonnet-4-6

# --- Embeddings (must match Supabase ingest: all-MiniLM-L6-v2, 384-d, no key) ---
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# --- Semantic cache tuning ---
CACHE_CAPACITY=1000
CACHE_THETA=0.92
DOCS_TTL_SECONDS=2592000
RECO_TTL_SECONDS=900

# --- Retrieval ---
DOCS_TOP_K=8
LIBS_TOP_K=8

# --- Transport (streamable HTTP) ---
LOCKSTEP_HOST=127.0.0.1
LOCKSTEP_PORT=8000

# --- Python interpreter for MCP server (Devin CLI) ---
# Set this to your Python path (e.g., /opt/anaconda3/envs/cs178/bin/python or just "python3")
LOCKSTEP_PYTHON=python3

# --- Observability ---
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Webhook secret from Sentry → Settings → Integrations → Webhooks (optional but recommended)
SENTRY_WEBHOOK_SECRET=
WEBHOOK_PORT=8001
